  "keyFeatures": [
    "Double-entry ledger with strict debit/credit balance enforcement",
    "Stablecoin settlement tracking (USDC, USDT, BRZ, PYUSD) across EVM, Solana, and Tron",
    "Fiat and on-chain journal entries with multi-currency support (USD, BRL, MXN, EUR)",
    "Idempotent transaction posting with client-supplied keys",
    "Agent policy rules for controlling automated transaction permissions",
    "Compliance audit log export in NDJSON format",
    "Webhook notifications for tenant events",
    "Fine-grained API key scopes for least-privilege access control",
    "Account statements with opening/closing balances and movements",
    "Manual batch reconciliation for unmatched transactions"
  ],
  "publicApiSurface": [
    "POST /api/v1/transactions",
    "GET /api/v1/accounts",
    "POST /api/v1/accounts",
